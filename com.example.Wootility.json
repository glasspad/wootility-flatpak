{
  "app-id": "com.example.Wootility",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "23.08",
  "sdk": "org.freedesktop.Sdk",
  "command": "wootility",
  "finish-args": [
    "--share=network",
    "--socket=wayland",
    "--socket=x11",

   
    "--device=all"
  ],
  "modules": [
    {
      "name": "wootility",
      "buildsystem": "simple",
      "build-commands": [
        "npm install",
        "mkdir -p /app/wootility",
        "cp -r . /app/wootility",
        "install -Dm755 node_modules/.bin/electron /app/bin/wootility"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ]
    }
  ]
}